---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StackMCP — MCP-powered workflow stacks</title>
    <meta
      name="description"
      content="The execution layer for MCP workflows. Install once, run from anywhere."
    />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <header class="header">
      <div class="container flex items-center">
        <div class="flex items-center">
          <a class="header-logo me-4" href="/">
            <svg role="img" aria-label="StackMCP" height="28" viewBox="0 0 150 28" width="150" xmlns="http://www.w3.org/2000/svg">
              <svg x="0" y="0" width="26" height="28" viewBox="180 180 660 750" overflow="visible">
                <defs>
                  <linearGradient id="botTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#2E528A"/><stop offset="100%" stop-color="#1A3A6A"/>
                  </linearGradient>
                  <linearGradient id="botLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#1A3A6A"/><stop offset="100%" stop-color="#0E2442"/>
                  </linearGradient>
                  <linearGradient id="botRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#142E52"/><stop offset="100%" stop-color="#081830"/>
                  </linearGradient>
                  <linearGradient id="midTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#5A8CFF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#7AA6FF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#346BFF"/><stop offset="100%" stop-color="#2550CC"/>
                  </linearGradient>
                  <linearGradient id="topTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#93C8FF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#B0DCFF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#6FAEFF"/><stop offset="100%" stop-color="#5290E0"/>
                  </linearGradient>
                </defs>
                <g transform="translate(512 680)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#botTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#botLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#botRight)"/>
                </g>
                <g transform="translate(512 520)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#midTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#midLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#midRight)"/>
                </g>
                <g transform="translate(512 360)">
                  <polygon points="0,-100 230,0 0,100 -230,0" fill="url(#topTop)"/>
                  <polygon points="-230,0 0,100 0,180 -230,80" fill="url(#topLeft)"/>
                  <polygon points="230,0 0,100 0,180 230,80" fill="url(#topRight)"/>
                </g>
              </svg>
              <text x="30" y="20" fill="currentColor" font-family="Sora, Inter, sans-serif" font-weight="600" font-size="20" letter-spacing="-0.02">StackMCP</text>
            </svg>
          </a>
        </div>
        <div class="group w-full">
          <ul class="text-sm hidden md:flex items-center">
            <li><a class="nav-link" href="#install">Install</a></li>
            <li><a class="nav-link" href="/docs/daemon-model.md">Docs</a></li>
            <li class="flex-grow" aria-hidden="true"></li>
            <li><a class="nav-link" href="https://github.com/StackMCP/stackmcp">GitHub</a></li>
          </ul>
        </div>
        <div class="ms-auto md:hidden z-10 flex items-center gap-4">
          <a class="header-mobile-nav" href="#" aria-label="Open the navigation menu">
            <div class="header-mobile-nav-button">
              <div class="header-mobile-nav-button-inner"></div>
            </div>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div style="padding-top: 6rem;">
      <header class="container mb-12">
        <div>
          <div class="max-w-[42rem] text-center sm:text-start">
            <h1 class="text-[9vw] font-semibold leading-[1.1] tracking-tight sm:text-title mb-8">
              StackMCP is the execution layer for <span style="color: var(--color-accent);">MCP workflows.</span>
            </h1>
            <p class="text-xl sm:text-3xl font-normal mb-6 max-w-xl text-pretty mx-auto sm:mx-0" style="color: #a1a1aa;">
              Run, trace, audit, and reuse tool workflows across CLI, agents, local apps, and MCP servers.
            </p>
          </div>

          <div class="py-6 mt-4">
            <div class="install-box" id="install">
              <div class="install-box-header">
                <span class="install-box-dot" style="background: #ef4444;"></span>
                <span class="install-box-dot" style="background: #f59e0b;"></span>
                <span class="install-box-dot" style="background: #22c55e;"></span>
                <span class="install-box-label">Install</span>
              </div>
              <div class="install-box-body">
                <code class="install-box-command">npm install -g stackmcp</code>
                <button class="install-box-copy" onclick="navigator.clipboard.writeText('npm install -g stackmcp')" aria-label="Copy install command">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  Copy
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>
    </div>

    <!-- Stack Builder visual -->
    <section id="demo" style="padding: 0 0 5rem;">
      <div class="container">
        <div class="builder-frame">
          <!-- Sidebar -->
          <div class="builder-sidebar">
            <div class="sidebar-header">Tools</div>
            <div class="sidebar-search">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="7.5"/><line x1="16" y1="16" x2="21" y2="21"/></svg>
              Search tools...
            </div>
            <div class="sidebar-section-label">Installed</div>
            <div class="sidebar-tool-group expanded">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                <span class="sidebar-server-icon" style="color:#ff4545;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </span>
                <span>YouTube</span>
              </div>
              <div class="sidebar-tools-sub">
                <div class="sidebar-tool-item active">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>
                  get_transcript
                </div>
                <div class="sidebar-tool-item">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>
                  search_videos
                </div>
              </div>
            </div>
            <div class="sidebar-tool-group">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                <span class="sidebar-server-icon" style="color:#7c5cfc;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                </span>
                <span>Transcript</span>
              </div>
            </div>
            <div class="sidebar-tool-group expanded">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                <span class="sidebar-server-icon" style="color:var(--color-accent);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
                </span>
                <span>AI Summary</span>
              </div>
              <div class="sidebar-tools-sub">
                <div class="sidebar-tool-item active">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>
                  summarize
                </div>
              </div>
            </div>
            <div class="sidebar-tool-group">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                <span class="sidebar-server-icon" style="color:#f59e0b;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9" /><path d="M4 4a16 16 0 0 1 16 16" /><circle cx="5" cy="19" r="1"/></svg>
                </span>
                <span>RSS</span>
              </div>
            </div>
            <div class="sidebar-tool-group expanded">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                <span class="sidebar-server-icon" style="color:var(--color-accent);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18" /></svg>
                </span>
                <span>Obsidian</span>
              </div>
              <div class="sidebar-tools-sub">
                <div class="sidebar-tool-item active">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>
                  write_note
                </div>
              </div>
            </div>
            <div class="sidebar-tool-group">
              <div class="sidebar-server">
                <svg class="sidebar-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                <span class="sidebar-server-icon" style="color:#34d399;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M22 8H2"/></svg>
                </span>
                <span>Gmail</span>
              </div>
            </div>
          </div>

          <!-- Canvas -->
          <div class="canvas-container">
            <!-- Dot grid background -->
            <svg class="canvas-bg" viewBox="0 0 440 380" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <defs>
                <pattern id="canvas-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                  <circle cx="1" cy="1" r="0.8" fill="rgba(62, 85, 113, 0.12)"></circle>
                </pattern>
              </defs>
              <rect x="0" y="0" width="440" height="380" fill="url(#canvas-dots)"></rect>
            </svg>

            <!-- Edge paths -->
            <svg class="canvas-edges" viewBox="0 0 440 380" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <defs>
                <marker id="arrow" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="7" markerHeight="7" orient="auto">
                  <path d="M 0 0 L 10 5 L 0 10 z" fill="rgba(100, 140, 200, 0.5)"/>
                </marker>
              </defs>
              <path d="M 220 100 L 220 158" fill="none" stroke="rgba(100, 140, 200, 0.5)" stroke-width="2.5" marker-end="url(#arrow)"/>
              <path d="M 220 220 L 220 278" fill="none" stroke="rgba(100, 140, 200, 0.5)" stroke-width="2.5" marker-end="url(#arrow)"/>
            </svg>

            <!-- Node: YouTube -->
            <div class="canvas-node" style="top: 40px; left: 140px;">
              <div class="canvas-node-header" style="color: #ff4545;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#ff4545"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                YouTube
              </div>
              <div class="canvas-node-body">
                <div class="canvas-node-field">
                  <span class="canvas-node-field-label">action</span>
                  <span class="canvas-node-field-value">fetch transcript</span>
                </div>
              </div>
            </div>

            <!-- Node: AI Summary -->
            <div class="canvas-node" style="top: 160px; left: 140px;">
              <div class="canvas-node-header" style="color: var(--color-accent);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
                AI Summary
              </div>
              <div class="canvas-node-body">
                <div class="canvas-node-field">
                  <span class="canvas-node-field-label">prompt</span>
                  <span class="canvas-node-field-value">summarize this transcript</span>
                </div>
              </div>
            </div>

            <!-- Node: Obsidian -->
            <div class="canvas-node" style="top: 280px; left: 140px;">
              <div class="canvas-node-header" style="color: var(--color-accent);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18" /></svg>
                Obsidian Note
              </div>
              <div class="canvas-node-body">
                <div class="canvas-node-field">
                  <span class="canvas-node-field-label">target</span>
                  <span class="canvas-node-field-value">Everything/Web/</span>
                </div>
              </div>
            </div>

          </div>

          <!-- Inspector -->
          <aside class="builder-inspector">
            <div class="inspector-head">
              <div class="inspector-node-info">
                <div class="inspector-logo-placeholder"></div>
                <div>
                  <span class="inspector-step-label">Select a step</span>
                  <strong class="inspector-tool-name">No node selected</strong>
                  <p class="inspector-action-name">Click a node to configure</p>
                </div>
              </div>
            </div>
            <nav class="inspector-tabs">
              <span class="inspector-tab active">Configure</span>
              <span class="inspector-tab">Input / Output</span>
              <span class="inspector-tab">Test</span>
            </nav>
            <div class="inspector-body">
              <div class="inspector-tab-panel active">
                <p class="inspector-empty">Select a node to see its configuration</p>
                <div class="inspector-section">
                  <div class="inspector-collapse-head">
                    <h3>Output (Preview)</h3>
                    <span class="inspector-collapse-icon">▼</span>
                  </div>
                </div>
              </div>
            </div>
          </aside>

          <div class="builder-bottom-dock" style="position: relative; overflow: hidden;">
            <svg class="dock-bg" style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none;" aria-hidden="true">
              <rect fill="url(#canvas-dots)" width="100%" height="100%"/>
            </svg>
            <nav class="dock-tabs" style="position: relative; z-index: 1;">
              <button class="dock-tab active">Stack Properties</button>
              <button class="dock-tab">Input Schema</button>
              <button class="dock-tab">Output Schema</button>
              <button class="dock-tab">Variables</button>
              <button class="dock-tab">Notes</button>
              <button class="dock-tab">Execution Preview</button>
            </nav>
            <div class="dock-body">
              <div class="dock-panel active">
                <div class="dock-props">
                  <div class="dock-stat">
                    <span class="dock-stat-value">youtube-to-obsidian</span>
                    <span class="dock-stat-label">Name</span>
                  </div>
                  <div class="dock-stat">
                    <span class="dock-stat-value">3</span>
                    <span class="dock-stat-label">Steps</span>
                  </div>
                  <div class="dock-stat">
                    <span class="dock-stat-value">~1 min</span>
                    <span class="dock-stat-label">Est. duration</span>
                  </div>
                </div>
                <div class="dock-settings">
                  <h4 class="dock-settings-title">Settings</h4>
                  <div class="dock-setting">
                    <div>
                      <strong>Stop on Error</strong>
                      <small>Stop execution if any step fails</small>
                    </div>
                    <span class="dock-toggle on">On</span>
                  </div>
                  <div class="dock-setting">
                    <div>
                      <strong>Retry Failed Steps</strong>
                      <small>Retry failed steps up to 3 times</small>
                    </div>
                    <span class="dock-toggle on">On</span>
                  </div>
                  <div class="dock-setting">
                    <div>
                      <strong>Timeout</strong>
                      <small>Set a timeout for each step</small>
                    </div>
                    <span class="dock-chip">3 mins</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="canvas-caption-wrapper">
          <div class="canvas-caption-badge">stackmcp run youtube-to-obsidian</div>
          <p class="canvas-caption-text">
            A premade stack in the Stack Builder — drag, connect, configure tools.
            <a href="#install" style="color: var(--color-accent);">Install</a> and try it in seconds.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          How it works
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Define
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Compose tools and APIs into a workflow stack. Each stack is a
              reusable JSON template.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Run
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Trigger stacks from your terminal or AI assistant. The daemon
              handles all MCP server connections.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Share
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Export any stack as a shareable template. Use community stacks
              or publish your own.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why -->
    <section class="section">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          Why StackMCP
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Local-first
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Runs on your machine. No cloud proxy, no data leaving your
              environment unless you route it.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Uses MCP
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Built on the Model Context Protocol. Works with any MCP-compatible
              AI assistant.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Reusable
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Stacks are portable JSON. Share them, version them, build on
              existing ones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start -->
    <section class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 600px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 0.75rem;">

---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StackMCP — MCP-powered workflow stacks</title>
    <meta
      name="description"
      content="Build and run MCP-powered workflows across your tools. Connect MCP servers, AI tools, and services into reusable stacks."
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Nav -->
    <nav
      style="
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 1.5rem;
        max-width: var(--max-width);
        margin: 0 auto;
        background: rgba(12, 12, 12, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      "
    >
      <span
        style="
          font-weight: 700;
          font-size: 1.05rem;
          letter-spacing: -0.02em;
        "
      >
        StackMCP
      </span>
      <div style="display: flex; gap: 1.75rem; font-size: 0.85rem;">
        <a href="#how-it-works" style="color: var(--color-text-muted);">How it works</a>
        <a href="#why" style="color: var(--color-text-muted);">Why StackMCP</a>
        <a
          href="#waitlist"
          style="
            background: var(--color-accent);
            color: #fff;
            padding: 0.35rem 0.9rem;
            border-radius: var(--radius-sm);
            font-weight: 500;
            font-size: 0.8rem;
          "
        >
          Waitlist
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <header style="padding: 7rem 0 5rem; text-align: center;">
      <div class="container">
        <h1
          style="
            font-size: clamp(2.75rem, 7vw, 4.5rem);
            font-weight: 800;
            line-height: 1.05;
            letter-spacing: -0.035em;
            margin-bottom: 1.25rem;
          "
        >
          Build MCP workflows<br />
          <span style="color: var(--color-accent);">across your stack</span>
        </h1>
        <p
          style="
            font-size: 1.1rem;
            color: var(--color-text-muted);
            max-width: 520px;
            margin: 0 auto 2.5rem;
            line-height: 1.7;
          "
        >
          StackMCP connects AI assistants, APIs, and local tools into reusable
          workflow stacks — all running locally through the Model Context
          Protocol.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a
            href="#waitlist"
            style="
              display: inline-flex;
              align-items: center;
              gap: 0.5rem;
              background: var(--color-accent);
              color: #fff;
              font-weight: 600;
              font-size: 0.95rem;
              padding: 0.8rem 1.75rem;
              border-radius: var(--radius-sm);
              transition: background 0.15s, transform 0.15s;
            "
            onmouseover="this.style.background='var(--color-accent-hover)'; this.style.transform='translateY(-1px)'"
            onmouseout="this.style.background='var(--color-accent)'; this.style.transform='translateY(0)'"
          >
            Join the waitlist
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a
            href="#how-it-works"
            style="
              display: inline-flex;
              align-items: center;
              gap: 0.5rem;
              color: var(--color-text);
              font-weight: 500;
              font-size: 0.95rem;
              padding: 0.8rem 1.75rem;
              border: 1px solid var(--color-border);
              border-radius: var(--radius-sm);
              transition: border-color 0.15s;
            "
            onmouseover="this.style.borderColor='var(--color-text-muted)'"
            onmouseout="this.style.borderColor='var(--color-border)'"
          >
            How it works
          </a>
        </div>

        <!-- Workflow visualization mockup -->
        <div
          style="
            margin-top: 4rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 2rem 2rem 2.5rem;
            text-align: left;
          "
        >
          <div
            style="
              display: flex;
              align-items: center;
              gap: 0.5rem;
              margin-bottom: 1.75rem;
            "
          >
            <span
              style="
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                font-family: var(--font-mono);
                font-size: 0.7rem;
                color: var(--color-text-dim);
                letter-spacing: 0.03em;
              "
            >
              <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #22c55e;"></span>
              stackmcp daemon
            </span>
            <span style="flex: 1;"></span>
            <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-text-dim);">
              ~/stacks
            </span>
          </div>

          <div
            style="
              display: flex;
              flex-direction: column;
              gap: 0.6rem;
              font-family: var(--font-mono);
              font-size: 0.78rem;
              color: var(--color-text-muted);
            "
          >
            <div style="display: flex; align-items: center; gap: 0.6rem; opacity: 0.5;">
              <span style="color: var(--color-text-dim);">$</span>
              <span>ls stacks/</span>
            </div>
            <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; padding-left: 1.2rem;">
              <span class="mock-tag">youtube-to-obsidian</span>
              <span class="mock-tag">github-pr-summary</span>
              <span class="mock-tag">slack-to-notion</span>
              <span class="mock-tag">code-review</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.6rem; margin-top: 0.4rem;">
              <span style="color: var(--color-text-dim);">$</span>
              <span>run <span style="color: var(--color-accent);">youtube-to-obsidian</span></span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.6rem; opacity: 0.6;">
              <span style="color: var(--color-green);">✓</span>
              <span style="color: var(--color-text-dim);">Fetching metadata...</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.6rem; opacity: 0.6;">
              <span style="color: var(--color-green);">✓</span>
              <span style="color: var(--color-text-dim);">Generating summary...</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.6rem;">
              <span style="color: var(--color-green);">✓</span>
              <span style="color: var(--color-text-dim);">Created note in Obsidian vault</span>
              <span style="color: var(--color-text-dim); font-size: 0.65rem;">(142ms)</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- How it works -->
    <section id="how-it-works" class="section" style="background: var(--color-surface);">
      <div class="container">
        <div style="text-align: center; margin-bottom: 3.5rem;">
          <span class="section-label">How it works</span>
          <h2 class="section-title">
            Define, run, and share.
          </h2>
          <p
            style="
              font-size: 1.05rem;
              color: var(--color-text-muted);
              max-width: 480px;
              margin: 0 auto;
              line-height: 1.7;
            "
          >
            StackMCP runs as a local daemon, connecting your tools through the
            Model Context Protocol.
          </p>
        </div>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
          "
        >
          <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
            <div
              style="
                width: 3rem;
                height: 3rem;
                border-radius: 50%;
                background: rgba(124, 92, 252, 0.12);
                color: var(--color-accent);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1rem;
                margin-bottom: 1.25rem;
              "
            >
              1
            </div>
            <h3 style="font-weight: 600; font-size: 1.05rem; margin-bottom: 0.6rem;">
              Define your stack
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.7;">
              Compose tools, APIs, and data sources into a workflow stack.
              Define it as a reusable JSON template.
            </p>
          </div>

          <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
            <div
              style="
                width: 3rem;
                height: 3rem;
                border-radius: 50%;
                background: rgba(124, 92, 252, 0.12);
                color: var(--color-accent);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1rem;
                margin-bottom: 1.25rem;
              "
            >
              2
            </div>
            <h3 style="font-weight: 600; font-size: 1.05rem; margin-bottom: 0.6rem;">
              Run with AI
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.7;">
              Trigger workflows through an AI assistant or on a schedule. The
              daemon manages connections and execution.
            </p>
          </div>

          <div class="card" style="text-align: center; padding: 2.5rem 1.75rem;">
            <div
              style="
                width: 3rem;
                height: 3rem;
                border-radius: 50%;
                background: rgba(124, 92, 252, 0.12);
                color: var(--color-accent);
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1rem;
                margin-bottom: 1.25rem;
              "
            >
              3
            </div>
            <h3 style="font-weight: 600; font-size: 1.05rem; margin-bottom: 0.6rem;">
              Share as templates
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.7;">
              Export your stack as a shareable template. Browse community
              workflows or publish your own.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Example workflow -->
    <section class="section">
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <span class="section-label">Example workflow</span>
          <h2 class="section-title">
            YouTube to Obsidian
          </h2>
          <p
            style="
              font-size: 1rem;
              color: var(--color-text-muted);
              max-width: 500px;
              margin: 0 auto;
              line-height: 1.7;
            "
          >
            A single prompt transforms a YouTube URL into a formatted Obsidian
            note.
          </p>
        </div>

        <!-- Pipeline visualization -->
        <div
          style="
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 2.5rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
          "
        >
          <span class="pipe-step">YouTube URL</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2" style="flex-shrink: 0;">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="pipe-step">Fetch metadata</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2" style="flex-shrink: 0;">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="pipe-step">AI summary</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2" style="flex-shrink: 0;">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="pipe-step" style="border-color: rgba(124, 92, 252, 0.4); color: var(--color-accent);">Obsidian note</span>
        </div>

        <div
          style="
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.5rem;
          "
        >
          <a
            href="/examples/youtube-to-obsidian.md"
            style="
              font-size: 0.85rem;
              color: var(--color-text-muted);
              display: inline-flex;
              align-items: center;
              gap: 0.35rem;
            "
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            Read the walkthrough
          </a>
          <a
            href="/templates/youtube-to-obsidian.json"
            style="
              font-size: 0.85rem;
              color: var(--color-text-muted);
              display: inline-flex;
              align-items: center;
              gap: 0.35rem;
            "
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" />
            </svg>
            View template
          </a>
        </div>
      </div>
    </section>

    <!-- Why StackMCP -->
    <section id="why" class="section" style="background: var(--color-surface);">
      <div class="container">
        <div style="text-align: center; margin-bottom: 3.5rem;">
          <span class="section-label">Why StackMCP</span>
          <h2 class="section-title">
            Your tools, connected through MCP.
          </h2>
          <p
            style="
              font-size: 1rem;
              color: var(--color-text-muted);
              max-width: 450px;
              margin: 0 auto;
              line-height: 1.7;
            "
          >
            Built for developers who want AI to work where their data already
            lives.
          </p>
        </div>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
          "
        >
          <div
            class="card"
            style="
              display: flex;
              flex-direction: column;
              gap: 0.75rem;
            "
          >
            <div
              style="
                width: 2.25rem;
                height: 2.25rem;
                border-radius: var(--radius-sm);
                background: rgba(124, 92, 252, 0.12);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
              "
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </div>
            <div>
              <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.35rem;">
                Local-first
              </h3>
              <p style="color: var(--color-text-muted); font-size: 0.85rem; line-height: 1.7;">
                Everything runs on your machine. No cloud proxy, no data leaving your environment unless you
                explicitly route it.
              </p>
            </div>
          </div>

          <div
            class="card"
            style="
              display: flex;
              flex-direction: column;
              gap: 0.75rem;
            "
          >
            <div
              style="
                width: 2.25rem;
                height: 2.25rem;
                border-radius: var(--radius-sm);
                background: rgba(124, 92, 252, 0.12);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
              "
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
              </svg>
            </div>
            <div>
              <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.35rem;">
                AI-native
              </h3>
              <p style="color: var(--color-text-muted); font-size: 0.85rem; line-height: 1.7;">
                Built on the Model Context Protocol. Works with any MCP-compatible AI assistant — Claude, and
                others.
              </p>
            </div>
          </div>

          <div
            class="card"
            style="
              display: flex;
              flex-direction: column;
              gap: 0.75rem;
            "
          >
            <div
              style="
                width: 2.25rem;
                height: 2.25rem;
                border-radius: var(--radius-sm);
                background: rgba(124, 92, 252, 0.12);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
              "
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 3 21 3 21 8" /><line x1="4" y1="20" x2="21" y2="3" /><polyline points="21 16 21 21 16 21" /><line x1="15" y1="15" x2="21" y2="21" /><line x1="4" y1="4" x2="9" y2="9" />
              </svg>
            </div>
            <div>
              <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.35rem;">
                Reusable stacks
              </h3>
              <p style="color: var(--color-text-muted); font-size: 0.85rem; line-height: 1.7;">
                Workflows are defined as portable JSON templates. Share them, version them, and build on
                existing stacks.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Waitlist CTA -->
    <section id="waitlist" class="section">
      <div class="container" style="text-align: center;">
        <div
          style="
            max-width: 520px;
            margin: 0 auto;
            padding: 3rem 2.5rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
          "
        >
          <span class="section-label">Stay in touch</span>
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">
            Join the waitlist
          </h2>
          <p
            style="
              color: var(--color-text-muted);
              font-size: 0.9rem;
              margin-bottom: 1.75rem;
              line-height: 1.7;
            "
          >
            StackMCP is in active development. Sign up to hear about releases,
            early access, and community updates.
          </p>

          <form id="waitlist-form"
            style="
              display: flex;
              gap: 0.5rem;
              max-width: 380px;
              margin: 0 auto;
            "
          >
            <input
              type="email"
              placeholder="you@example.com"
              required
              style="
                flex: 1;
                padding: 0.7rem 1rem;
                border: 1px solid var(--color-border);
                border-radius: var(--radius-sm);
                background: var(--color-bg);
                color: var(--color-text);
                font-size: 0.9rem;
                font-family: inherit;
                outline: none;
                transition: border-color 0.15s;
              "
              onfocus="this.style.borderColor='var(--color-accent)'"
              onblur="this.style.borderColor='var(--color-border)'"
            />
            <button
              type="submit"
              style="
                background: var(--color-accent);
                color: #fff;
                border: none;
                padding: 0.7rem 1.25rem;
                border-radius: var(--radius-sm);
                font-weight: 600;
                font-size: 0.9rem;
                font-family: inherit;
                cursor: pointer;
                white-space: nowrap;
                transition: background 0.15s;
              "
              onmouseover="this.style.background='var(--color-accent-hover)'"
              onmouseout="this.style.background='var(--color-accent)'"
            >
              Join
            </button>
          </form>

          <p
            style="
              margin-top: 1.25rem;
              color: var(--color-text-dim);
              font-size: 0.75rem;
            "
          >
            No spam, just project updates. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </section>

    <script>
      document
        .getElementById("waitlist-form")
        ?.addEventListener("submit", (e) => {
          e.preventDefault();
          alert("Waitlist coming soon — thanks for your interest!");
        });
    </script>

    <!-- Footer -->
    <footer
      style="
        border-top: 1px solid var(--color-border);
        padding: 2.5rem 0;
        margin-top: 1rem;
      "
    >
      <div
        class="container"
        style="
          display: flex;
          flex-wrap: wrap;
          justify-content: space-between;
          align-items: center;
          gap: 1rem;
          font-size: 0.8rem;
          color: var(--color-text-muted);
        "
      >
        <div style="display: flex; gap: 1.5rem; align-items: center;">
          <a href="https://github.com/StackMCP/stackmcp" style="color: var(--color-text-muted);">GitHub</a>
          <a href="/ROADMAP.md" style="color: var(--color-text-muted);">Roadmap</a>
          <a href="/CONTRIBUTING.md" style="color: var(--color-text-muted);">Contributing</a>
        </div>

        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <span
            style="
              display: inline-block;
              width: 6px;
              height: 6px;
              border-radius: 50%;
              background: #22c55e;
            "
          ></span>
          Early development
        </div>
      </div>
    </footer>

    <style is:global>
      .pipe-step {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        padding: 0.6rem 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        transition: border-color 0.15s, color 0.15s;
      }
      .pipe-step:hover {
        border-color: rgba(124, 92, 252, 0.3);
        color: var(--color-accent);
      }
      .mock-tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        padding: 0.25rem 0.6rem;
        background: rgba(124, 92, 252, 0.1);
        color: var(--color-accent);
        border-radius: 4px;
        white-space: nowrap;
      }
      @media (max-width: 640px) {
        .pipe-step {
          font-size: 0.75rem;
          padding: 0.4rem 0.65rem;
        }
        nav div:first-child + div {
          gap: 0.75rem;
        }
      }
    </style>
  </body>
</html>

---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StackMCP — MCP-powered workflow stacks</title>
    <meta
      name="description"
      content="The execution layer for MCP workflows. Install once, run from anywhere."
    />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <header class="header">
      <div class="container flex items-center">
        <div class="flex items-center">
          <a class="header-logo me-4" href="/">
            <svg role="img" aria-label="StackMCP" height="28" viewBox="0 0 150 28" width="150" xmlns="http://www.w3.org/2000/svg">
              <svg x="0" y="0" width="26" height="28" viewBox="180 180 660 750" overflow="visible">
                <defs>
                  <linearGradient id="botTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#2E528A"/><stop offset="100%" stop-color="#1A3A6A"/>
                  </linearGradient>
                  <linearGradient id="botLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#1A3A6A"/><stop offset="100%" stop-color="#0E2442"/>
                  </linearGradient>
                  <linearGradient id="botRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#142E52"/><stop offset="100%" stop-color="#081830"/>
                  </linearGradient>
                  <linearGradient id="midTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#5A8CFF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#7AA6FF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#346BFF"/><stop offset="100%" stop-color="#2550CC"/>
                  </linearGradient>
                  <linearGradient id="topTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#93C8FF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#B0DCFF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#6FAEFF"/><stop offset="100%" stop-color="#5290E0"/>
                  </linearGradient>
                </defs>
                <g transform="translate(512 680)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#botTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#botLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#botRight)"/>
                </g>
                <g transform="translate(512 520)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#midTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#midLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#midRight)"/>
                </g>
                <g transform="translate(512 360)">
                  <polygon points="0,-100 230,0 0,100 -230,0" fill="url(#topTop)"/>
                  <polygon points="-230,0 0,100 0,180 -230,80" fill="url(#topLeft)"/>
                  <polygon points="230,0 0,100 0,180 230,80" fill="url(#topRight)"/>
                </g>
              </svg>
              <text x="30" y="20" fill="currentColor" font-family="Sora, Inter, sans-serif" font-weight="600" font-size="20" letter-spacing="-0.02">StackMCP</text>
            </svg>
          </a>
        </div>
        <div class="group w-full">
          <ul class="text-sm hidden md:flex items-center">
            <li><a class="nav-link" href="#install">Install</a></li>
            <li><a class="nav-link" href="/docs/daemon-model.md">Docs</a></li>
            <li class="flex-grow" aria-hidden="true"></li>
            <li><a class="nav-link" href="https://github.com/StackMCP/stackmcp">GitHub</a></li>
          </ul>
        </div>
        <div class="ms-auto md:hidden z-10 flex items-center gap-4">
          <a class="header-mobile-nav" href="#" aria-label="Open the navigation menu">
            <div class="header-mobile-nav-button">
              <div class="header-mobile-nav-button-inner"></div>
            </div>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div style="padding-top: 6rem;">
      <header class="container mb-12">
        <div>
          <div class="max-w-[42rem] text-center sm:text-start">
            <h1 class="text-[9vw] font-semibold leading-[1.1] tracking-tight sm:text-title mb-8">
              StackMCP is the execution layer for <span style="color: var(--color-accent);">MCP workflows.</span>
            </h1>
            <p class="text-xl sm:text-3xl font-normal mb-6 max-w-xl text-pretty mx-auto sm:mx-0" style="color: #a1a1aa;">
              Run, trace, audit, and reuse tool workflows across CLI, agents, local apps, and MCP servers.
            </p>
          </div>

          <div class="py-6 mt-4">
            <div class="install-box" id="install">
              <div class="install-box-header">
                <span class="install-box-dot" style="background: #ef4444;"></span>
                <span class="install-box-dot" style="background: #f59e0b;"></span>
                <span class="install-box-dot" style="background: #22c55e;"></span>
                <span class="install-box-label">Install</span>
              </div>
              <div class="install-box-body">
                <code class="install-box-command">npm install -g stackmcp</code>
                <button class="install-box-copy" onclick="navigator.clipboard.writeText('npm install -g stackmcp')" aria-label="Copy install command">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  Copy
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>
    </div>

    <!-- Stack Builder visual -->
    <section id="demo" style="padding: 0 0 5rem;">
      <div class="container">
        <div class="canvas-container">
          <!-- Dot grid background -->
          <svg class="canvas-bg" aria-hidden="true">
            <defs>
              <pattern id="canvas-dots" x="8" y="8" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="1" cy="1" r="0.8" fill="rgba(62, 85, 113, 0.12)"></circle>
              </pattern>
            </defs>
            <rect x="0" y="0" width="100%" height="100%" fill="url(#canvas-dots)"></rect>
          </svg>

          <!-- Edge paths -->
          <svg class="canvas-edges" aria-hidden="true">
            <defs>
              <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 z" fill="rgba(100, 120, 160, 0.4)"/>
              </marker>
            </defs>
            <!-- YouTube → Transcript -->
            <path d="M 176 44 C 242 44, 242 118, 308 118" fill="none" stroke="rgba(100, 120, 160, 0.35)" stroke-width="2" marker-end="url(#arrow)"/>
            <!-- Transcript → AI Summary -->
            <path d="M 468 118 C 534 118, 534 44, 600 44" fill="none" stroke="rgba(100, 120, 160, 0.35)" stroke-width="2" marker-end="url(#arrow)"/>
            <!-- AI Summary → Obsidian -->
            <path d="M 760 44 C 826 44, 826 118, 892 118" fill="none" stroke="rgba(100, 120, 160, 0.35)" stroke-width="2" marker-end="url(#arrow)"/>
          </svg>

          <!-- Node: YouTube -->
          <div class="canvas-node" style="top: 16px; left: 16px;">
            <div class="canvas-node-header" style="color: #ff4545;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#ff4545">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </div>
            <div class="canvas-node-body">
              <div class="canvas-node-field">
                <span class="canvas-node-field-label">url</span>
                <span class="canvas-node-field-value">https://youtube.com/watch?v=...</span>
              </div>
            </div>
          </div>

          <!-- Node: Transcript -->
          <div class="canvas-node" style="top: 90px; left: 308px;">
            <div class="canvas-node-header">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" />
              </svg>
              Transcript
            </div>
            <div class="canvas-node-body">
              <div class="canvas-node-field">
                <span class="canvas-node-field-label">language</span>
                <span class="canvas-node-field-value">en</span>
              </div>
            </div>
          </div>

          <!-- Node: AI Summary -->
          <div class="canvas-node" style="top: 16px; left: 600px;">
            <div class="canvas-node-header" style="color: var(--color-accent);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
              </svg>
              AI Summary
            </div>
            <div class="canvas-node-body">
              <div class="canvas-node-field">
                <span class="canvas-node-field-label">prompt</span>
                <span class="canvas-node-field-value">summarize this transcript</span>
              </div>
            </div>
          </div>

          <!-- Node: Obsidian -->
          <div class="canvas-node" style="top: 90px; left: 892px;">
            <div class="canvas-node-header" style="color: var(--color-accent);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18" />
              </svg>
              Obsidian Note
            </div>
            <div class="canvas-node-body">
              <div class="canvas-node-field">
                <span class="canvas-node-field-label">target</span>
                <span class="canvas-node-field-value">Everything/Web/</span>
              </div>
            </div>
          </div>

        </div>

        <div class="canvas-caption-wrapper">
          <div class="canvas-caption-badge">stackmcp run youtube-to-obsidian</div>
          <p class="canvas-caption-text">
            A premade stack — tools connected in the Stack Builder, ready to run from the CLI.
            <a href="#install" style="color: var(--color-accent);">Install</a> and try it in seconds.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          How it works
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Define
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Compose tools and APIs into a workflow stack. Each stack is a
              reusable JSON template.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Run
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Trigger stacks from your terminal or AI assistant. The daemon
              handles all MCP server connections.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Share
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Export any stack as a shareable template. Use community stacks
              or publish your own.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why -->
    <section class="section">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          Why StackMCP
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Local-first
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Runs on your machine. No cloud proxy, no data leaving your
              environment unless you route it.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Uses MCP
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Built on the Model Context Protocol. Works with any MCP-compatible
              AI assistant.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Reusable
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Stacks are portable JSON. Share them, version them, build on
              existing ones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start -->
    <section class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 600px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 0.75rem;">
          Get started in seconds
        </h2>
        <p
          style="
            color: var(--color-text-muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
            line-height: 1.7;
          "
        >
          Install globally, configure your MCP servers, and run your first stack.
        </p>

        <div class="terminal-box">
          <div class="install-box-header">
            <span class="install-box-dot" style="background: #ef4444;"></span>
            <span class="install-box-dot" style="background: #f59e0b;"></span>
            <span class="install-box-dot" style="background: #22c55e;"></span>
            <span class="install-box-label" style="color: var(--color-text-muted);">Terminal</span>
          </div>
          <div class="terminal-body">
            <pre class="terminal-pre">$ stackmcp init
? Enable the Obsidian MCP server? Yes
? Enable the YouTube MCP server? Yes
✓ Servers configured

$ stackmcp stacks
  youtube-to-obsidian  Fetch transcript, summarize, save to vault
  ...

$ stackmcp run youtube-to-obsidian \
    --url "https://youtube.com/watch?v=..."
✓ Stack complete — note saved to Obsidian</pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer
      style="
        padding: 2rem 0;
        font-size: 0.8rem;
        color: var(--color-text-dim);
      "
    >
      <div
        class="container"
        style="
          display: flex;
          flex-wrap: wrap;
          justify-content: space-between;
          align-items: center;
          gap: 1rem;
        "
      >
        <div style="display: flex; gap: 1.25rem;">
          <a href="https://github.com/StackMCP/stackmcp" style="color: var(--color-text-dim);">GitHub</a>
          <a href="/ROADMAP.md" style="color: var(--color-text-dim);">Roadmap</a>
          <a href="/CONTRIBUTING.md" style="color: var(--color-text-dim);">Contributing</a>
        </div>
        <span>npm install -g stackmcp</span>
      </div>
    </footer>

    <style is:global>
      .canvas-container {
        position: relative;
        width: 100%;
        max-width: 1060px;
        margin: 0 auto;
        height: 180px;
        background: #13131b;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
      }

      .canvas-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }

      .canvas-edges {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }

      .canvas-node {
        position: absolute;
        width: 160px;
        background: #1a1a26;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-sm);
        overflow: hidden;
        z-index: 3;
        transition: border-color 0.15s;
      }

      .canvas-node:hover {
        border-color: rgba(59, 130, 246, 0.3);
      }

      .canvas-node-header {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 600;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(255, 255, 255, 0.03);
      }

      .canvas-node-body {
        padding: 0.4rem 0.65rem;
      }

      .canvas-node-field {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
      }

      .canvas-node-field-label {
        font-size: 0.6rem;
        color: var(--color-text-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .canvas-node-field-value {
        font-size: 0.7rem;
        color: var(--color-text-muted);
        font-family: var(--font-mono);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .canvas-caption-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        margin-top: 1.25rem;
        text-align: center;
      }

      .canvas-caption-badge {
        display: inline-block;
        padding: 0.35rem 1rem;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--color-accent);
        font-family: var(--font-mono);
      }

      .canvas-caption-text {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        max-width: 440px;
        line-height: 1.6;
      }

      @media (max-width: 1100px) {
        .canvas-container {
          max-width: 100%;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
        .canvas-container > * {
          min-width: 1060px;
        }
      }

      @media (max-width: 640px) {
        .canvas-container {
          height: 180px;
        }
        .canvas-node {
          width: 140px;
        }
      }

      .install-box {
        max-width: 500px;
        background: #1a1a2e;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        font-family: var(--font-mono);
      }

      .install-box-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 0.75rem;
        background: rgba(255, 255, 255, 0.04);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .install-box-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
      }

      .install-box-label {
        margin-left: 0.5rem;
        font-size: 0.7rem;
        color: var(--color-text-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .install-box-body {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1rem;
      }

      .install-box-command {
        font-size: 0.9rem;
        color: #e8e8ed;
        white-space: nowrap;
      }

      .install-box-copy {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.35rem 0.7rem;
        font-size: 0.75rem;
        font-family: var(--font-sans);
        background: rgba(255, 255, 255, 0.08);
        color: var(--color-text-muted);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }

      .install-box-copy:hover {
        background: var(--color-accent);
        color: #fff;
        border-color: var(--color-accent);
      }

      .install-box-copy:active {
        opacity: 0.8;
      }

      .terminal-box {
        max-width: 560px;
        margin: 0 auto;
        background: #1a1a2e;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        font-family: var(--font-mono);
        text-align: left;
      }

      .terminal-pre {
        font-size: 0.78rem;
        line-height: 1.7;
        color: #c4c4d0;
        padding: 1rem 1.25rem;
        white-space: pre-wrap;
        font-family: var(--font-mono);
      }
    </style>
  </body>
</html>

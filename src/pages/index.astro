---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StackMCP — MCP-powered workflow stacks</title>
    <meta
      name="description"
      content="Connect GitHub, Obsidian, YouTube, Gmail, RSS, Discord, and MCP servers into reusable workflow stacks."
    />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <header class="header">
      <div class="container flex items-center">
        <div class="flex items-center">
          <a class="header-logo me-4" href="/">
            <svg role="img" aria-label="StackMCP" height="28" viewBox="0 0 150 28" width="150" xmlns="http://www.w3.org/2000/svg">
              <svg x="0" y="0" width="26" height="28" viewBox="180 180 660 750" overflow="visible">
                <defs>
                  <linearGradient id="botTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#2E528A"/><stop offset="100%" stop-color="#1A3A6A"/>
                  </linearGradient>
                  <linearGradient id="botLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#1A3A6A"/><stop offset="100%" stop-color="#0E2442"/>
                  </linearGradient>
                  <linearGradient id="botRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#142E52"/><stop offset="100%" stop-color="#081830"/>
                  </linearGradient>
                  <linearGradient id="midTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#5A8CFF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#7AA6FF"/><stop offset="100%" stop-color="#346BFF"/>
                  </linearGradient>
                  <linearGradient id="midRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#346BFF"/><stop offset="100%" stop-color="#2550CC"/>
                  </linearGradient>
                  <linearGradient id="topTop" x1="25%" y1="15%" x2="80%" y2="95%">
                    <stop offset="0%" stop-color="#93C8FF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topLeft" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#B0DCFF"/><stop offset="100%" stop-color="#6FAEFF"/>
                  </linearGradient>
                  <linearGradient id="topRight" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#6FAEFF"/><stop offset="100%" stop-color="#5290E0"/>
                  </linearGradient>
                </defs>
                <g transform="translate(512 680)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#botTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#botLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#botRight)"/>
                </g>
                <g transform="translate(512 520)">
                  <polygon points="0,-100 220,0 0,100 -220,0" fill="url(#midTop)"/>
                  <polygon points="-220,0 0,100 0,170 -220,70" fill="url(#midLeft)"/>
                  <polygon points="220,0 0,100 0,170 220,70" fill="url(#midRight)"/>
                </g>
                <g transform="translate(512 360)">
                  <polygon points="0,-100 230,0 0,100 -230,0" fill="url(#topTop)"/>
                  <polygon points="-230,0 0,100 0,180 -230,80" fill="url(#topLeft)"/>
                  <polygon points="230,0 0,100 0,180 230,80" fill="url(#topRight)"/>
                </g>
              </svg>
              <text x="30" y="20" fill="currentColor" font-family="Sora, Inter, sans-serif" font-weight="600" font-size="20" letter-spacing="-0.02">StackMCP</text>
            </svg>
          </a>
        </div>
        <div class="group w-full">
          <ul class="text-sm hidden md:flex items-center">
            <li><a class="nav-link" href="https://github.com/StackMCP/stackmcp/releases">Download</a></li>
            <li><a class="nav-link" href="#waitlist">Pricing</a></li>
            <li><a class="nav-link" href="/docs/daemon-model.md">Sync</a></li>
            <li><a class="nav-link" href="/workflows/README.md">Publish</a></li>
            <li><a class="nav-link" href="#waitlist">Enterprise</a></li>
            <li class="flex-grow" aria-hidden="true"></li>
            <li><a class="nav-link" href="https://github.com/StackMCP/stackmcp">Community</a></li>
            <li><a class="nav-link" href="#waitlist">Account</a></li>
          </ul>
        </div>
        <div class="ms-auto md:hidden z-10 flex items-center gap-4">
          <a class="header-mobile-nav" href="#" aria-label="Open the navigation menu">
            <div class="header-mobile-nav-button">
              <div class="header-mobile-nav-button-inner"></div>
            </div>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <div style="padding-top: 6rem;">
      <header class="container mb-12">
        <div>
          <div class="max-w-[42rem] text-center sm:text-start">
            <h1 class="text-[9vw] font-semibold leading-[1.1] tracking-tight sm:text-title mb-8">
              Orchestrate your <span style="color: var(--color-accent);">AI workflows.</span>
            </h1>
            <p class="text-xl sm:text-3xl font-normal mb-6 max-w-xl text-pretty mx-auto sm:mx-0" style="color: #a1a1aa;">
              Build reusable AI workflows that reduce repeated prompts, preserve context, and save tokens.
            </p>
          </div>

          <div class="py-6 mt-4 flex items-center gap-6 flex-col sm:flex-row">
            <a class="download-button button-primary text-xl py-4 px-6" href="#demo">
              Try demo
            </a>
            <a class="text-accent text-lg hidden sm:block font-medium" href="#waitlist">
              Join&nbsp;waitlist
            </a>
          </div>
        </div>
      </header>

    </div>

    <!-- Workflow visual -->
    <section id="demo" style="padding: 0 0 5rem;">
      <div class="container" style="max-width: 600px;">
        <div
          style="
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 2.5rem 2rem;
          "
        >
          <div
            style="
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 0.75rem;
              font-size: 0.9rem;
            "
          >
            <!-- YouTube -->
            <div class="wf-node" style="background: rgba(255, 0, 0, 0.08); border-color: rgba(255, 0, 0, 0.2);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#ff0000">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </div>

            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2">
              <polyline points="8 6 2 12 8 18" />
            </svg>

            <!-- Transcript -->
            <div class="wf-node">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" />
              </svg>
              Transcript
            </div>

            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2">
              <polyline points="8 6 2 12 8 18" />
            </svg>

            <!-- AI Summary -->
            <div class="wf-node" style="border-color: rgba(59, 130, 246, 0.3); color: var(--color-accent);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
              </svg>
              AI Summary
            </div>

            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-dim)" stroke-width="2">
              <polyline points="8 6 2 12 8 18" />
            </svg>

            <!-- Obsidian -->
            <div class="wf-node" style="border-color: rgba(59, 130, 246, 0.4); color: var(--color-accent); font-weight: 600;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18" />
              </svg>
              Obsidian Note
            </div>
          </div>

          <p
            style="
              margin-top: 1.5rem;
              text-align: center;
              font-size: 0.8rem;
              color: var(--color-text-dim);
            "
          >
            "Save the transcript of this YouTube video to my Obsidian vault"
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          How it works
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Define
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Compose tools and APIs into a workflow stack. Each stack is a
              reusable JSON template.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Run
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Trigger stacks through an AI assistant or on a schedule. The
              daemon handles connections.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Share
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Export any stack as a shareable template. Use community stacks
              or publish your own.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why -->
    <section class="section">
      <div class="container" style="max-width: 800px; text-align: center;">
        <h2 class="section-title" style="margin-bottom: 3rem;">
          Why StackMCP
        </h2>

        <div
          style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            text-align: left;
          "
        >
          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Local-first
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Runs on your machine. No cloud proxy, no data leaving your
              environment unless you route it.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Uses MCP
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Built on the Model Context Protocol. Works with any MCP-compatible
              AI assistant.
            </p>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <h3 style="font-weight: 600; font-size: 1rem; margin-bottom: 0.5rem;">
              Reusable
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; line-height: 1.7;">
              Stacks are portable JSON. Share them, version them, build on
              existing ones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Waitlist -->
    <section id="waitlist" class="section" style="background: var(--color-surface);">
      <div class="container" style="max-width: 400px; text-align: center;">
        <h2 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 0.75rem;">
          Get early access
        </h2>
        <p
          style="
            color: var(--color-text-muted);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            line-height: 1.7;
          "
        >
          StackMCP is in active development. Sign up for release and early
          access updates.
        </p>

        <form id="waitlist-form"
          style="
            display: flex;
            gap: 0.5rem;
          "
        >
          <input
            type="email"
            placeholder="you@example.com"
            required
            style="
              flex: 1;
              padding: 0.65rem 1rem;
              border: 1px solid var(--color-border);
              border-radius: var(--radius-sm);
              background: var(--color-bg);
              color: var(--color-text);
              font-size: 0.85rem;
              font-family: inherit;
              outline: none;
              transition: border-color 0.15s;
            "
            onfocus="this.style.borderColor='var(--color-accent)'"
            onblur="this.style.borderColor='var(--color-border)'"
          />
          <button
            type="submit"
            style="
              background: var(--color-accent);
              color: #fff;
              border: none;
              padding: 0.65rem 1.25rem;
              border-radius: var(--radius-sm);
              font-weight: 600;
              font-size: 0.85rem;
              font-family: inherit;
              cursor: pointer;
              white-space: nowrap;
              transition: background 0.15s;
            "
            onmouseover="this.style.background='var(--color-accent-hover)'"
            onmouseout="this.style.background='var(--color-accent)'"
          >
            Join
          </button>
        </form>
      </div>
    </section>

    <script>
      document
        .getElementById("waitlist-form")
        ?.addEventListener("submit", (e) => {
          e.preventDefault();
          alert("Waitlist coming soon — thanks for your interest!");
        });
    </script>

    <!-- Footer -->
    <footer
      style="
        padding: 2rem 0;
        font-size: 0.8rem;
        color: var(--color-text-dim);
      "
    >
      <div
        class="container"
        style="
          display: flex;
          flex-wrap: wrap;
          justify-content: space-between;
          align-items: center;
          gap: 1rem;
        "
      >
        <div style="display: flex; gap: 1.25rem;">
          <a href="https://github.com/StackMCP/stackmcp" style="color: var(--color-text-dim);">GitHub</a>
          <a href="/ROADMAP.md" style="color: var(--color-text-dim);">Roadmap</a>
          <a href="/CONTRIBUTING.md" style="color: var(--color-text-dim);">Contributing</a>
        </div>
        <span>Early development</span>
      </div>
    </footer>

    <style is:global>
      .wf-node {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1.25rem;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 500;
        min-width: 140px;
        justify-content: center;
      }
    </style>
  </body>
</html>
